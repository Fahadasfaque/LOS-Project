<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml"
  xmlns:o="urn:schemas-microsoft-com:office:office">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="format-detection" content="telephone=no,address=no,email=no,date=no,url=no">
  <title>{{title}}</title>

  <!--[if mso]>
  <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
  <![endif]-->

  <style>
    /* ── RESET ─────────────────────────────────────────── */
    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    body,
    table,
    td,
    a {
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }

    table,
    td {
      mso-table-lspace: 0pt;
      mso-table-rspace: 0pt;
    }

    img {
      -ms-interpolation-mode: bicubic;
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
    }

    body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      background-color: #EEF0F5;
    }

    /* ── WRAPPER ────────────────────────────────────────── */
    .email-wrapper {
      width: 100%;
      background-color: #EEF0F5;
      padding: 32px 16px;
    }

    .email-container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #FFFFFF;
      border-radius: 4px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0, 31, 78, 0.10);
    }

    /* ── HEADER ─────────────────────────────────────────── */
    .header {
      background-color: #001F4E;
      padding: 36px 40px 32px;
      text-align: left;
    }

    .logo-wordmark {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 22px;
      font-weight: 800;
      color: #FFFFFF;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin: 0 0 10px 0;
      line-height: 1;
    }

    .logo-wordmark span {
      color: #C9A84C;
    }

    .logo-tagline {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 9px;
      color: #8FA8C8;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin: 0;
    }

    /* ── META STRIP ─────────────────────────────────────── */
    .meta-strip {
      background-color: #F0F4FA;
      border-bottom: 1px solid #DDE3EE;
      padding: 12px 40px;
    }

    .meta-strip-inner {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 11px;
      color: #7A8BA0;
      letter-spacing: 0.5px;
    }

    .meta-strip-inner strong {
      color: #001F4E;
      font-weight: 600;
    }

    /* ── CONTENT ────────────────────────────────────────── */
    .content {
      padding: 40px 40px 32px;
    }

    .email-title {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 26px;
      font-weight: 300;
      color: #0A0F1E;
      margin: 0 0 8px 0;
      line-height: 1.25;
      letter-spacing: -0.3px;
    }

    /* ── NOTICE BLOCK ───────────────────────────────────── */
    .notice-block {
      background-color: #FDF6EC;
      border-left: 4px solid #C9A84C;
      border-radius: 0 4px 4px 0;
      padding: 22px 28px;
      margin-bottom: 36px;
    }

    .notice-eyebrow {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 9px;
      font-weight: 700;
      color: #C9A84C;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      margin: 0 0 8px 0;
    }

    .notice-text {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 15px;
      color: #2D3748;
      margin: 0;
      line-height: 1.65;
    }

    /* ── INFO TABLE ─────────────────────────────────────── */
    .section-label {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 9px;
      font-weight: 700;
      color: #001F4E;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      margin: 0 0 14px 0;
    }

    .info-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 36px;
    }

    .info-table tr:first-child td,
    .info-table tr:first-child th {
      border-top: 1px solid #E2E8F0;
    }

    .info-table th,
    .info-table td {
      padding: 14px 0;
      border-bottom: 1px solid #E2E8F0;
      text-align: left;
      vertical-align: middle;
    }

    .info-table th {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: #7A8BA0;
      width: 42%;
      padding-right: 16px;
    }

    .info-table td {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: #0A0F1E;
    }

    /* ── STATUS BADGE ───────────────────────────────────── */
    .status-badge {
      display: inline-block;
      background-color: #EBF8F1;
      color: #1A6641;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 100px;
      border: 1px solid #B0DEC8;
    }

    /* ── TRANSACTION ID ─────────────────────────────────── */
    .transaction-id {
      font-family: 'Courier New', Courier, monospace;
      font-size: 13px;
      color: #001F4E;
      background-color: #F0F4FA;
      padding: 3px 8px;
      border-radius: 3px;
      letter-spacing: 0.5px;
    }

    /* ── SUPPORT BLOCK ──────────────────────────────────── */
    .support-block {
      background-color: #F8F7F4;
      border: 1px solid #E2E8F0;
      border-radius: 4px;
      padding: 20px 24px;
      margin-bottom: 8px;
      text-align: center;
    }

    .support-block p {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 13px;
      color: #4A5568;
      margin: 0 0 6px 0;
    }

    .support-block a {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: #001F4E;
      text-decoration: none;
      border-bottom: 1.5px solid #C9A84C;
      padding-bottom: 1px;
    }

    /* ── CONFIDENTIALITY STRIP ──────────────────────────── */
    .confidential-strip {
      background-color: #F0F4FA;
      border-top: 1px solid #DDE3EE;
      padding: 10px 40px;
      text-align: center;
    }

    .confidential-strip p {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 9px;
      color: #9AACBC;
      margin: 0;
      letter-spacing: 0.3px;
      line-height: 1.5;
    }

    /* ── FOOTER ─────────────────────────────────────────── */
    .footer {
      background-color: #0A0F1E;
      padding: 32px 40px;
    }

    .footer-logo {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: #FFFFFF;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin: 0 0 6px 0;
    }

    .footer-logo span {
      color: #C9A84C;
    }

    .footer-divider {
      width: 100%;
      height: 1px;
      background-color: #1E2A42;
      margin: 18px 0;
    }

    .footer-powered {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 11px;
      color: #8FA8C8;
      margin: 0 0 5px 0;
    }

    .footer-powered strong {
      color: #C9A84C;
      font-weight: 600;
    }

    .footer-slogan {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 11px;
      color: #4A5A72;
      font-style: italic;
      margin: 0 0 14px 0;
    }

    .footer-copy {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 10px;
      color: #3A4A5E;
      letter-spacing: 0.3px;
      margin: 0;
    }

    .footer-links {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 10px;
      margin: 8px 0 0 0;
    }

    .footer-links a {
      color: #5A7A9E;
      text-decoration: none;
      margin: 0 8px;
    }

    /* ── RESPONSIVE: TABLET / MOBILE ───────────────────── */
    @media only screen and (max-width: 600px) {
      .email-wrapper {
        padding: 0 !important;
      }

      .email-container {
        border-radius: 0 !important;
        box-shadow: none !important;
      }

      .header {
        padding: 28px 24px 24px !important;
      }

      .meta-strip {
        padding: 10px 24px !important;
      }

      .content {
        padding: 28px 24px 24px !important;
      }

      .notice-block {
        padding: 18px 20px !important;
      }

      .email-title {
        font-size: 22px !important;
      }

      .info-table th {
        font-size: 11px !important;
        width: 40% !important;
      }

      .info-table td {
        font-size: 13px !important;
      }

      .info-table th,
      .info-table td {
        padding: 12px 0 !important;
      }

      .footer {
        padding: 28px 24px !important;
      }

      .confidential-strip {
        padding: 10px 24px !important;
      }

      .status-badge {
        font-size: 10px !important;
      }

      .transaction-id {
        font-size: 11px !important;
        word-break: break-all;
      }
    }

    /* ── RESPONSIVE: NARROW (< 380 px) ─────────────────── */
    @media only screen and (max-width: 380px) {
      .email-title {
        font-size: 19px !important;
      }

      .info-table th,
      .info-table td {
        display: block !important;
        width: 100% !important;
        padding: 6px 0 !important;
      }

      .info-table tr td {
        padding-bottom: 12px !important;
        border-bottom: 1px solid #E2E8F0 !important;
      }

      .info-table tr th {
        border-bottom: none !important;
        padding-top: 12px !important;
      }
    }
  </style>
</head>

<body>
  <!-- ░░ PREVIEW TEXT (inbox snippet, hidden) ░░ -->
  <div
    style="display:none;font-size:1px;color:#ffffff;line-height:1px;max-height:0px;max-width:0px;opacity:0;overflow:hidden;">
    {{title}} — Fortress Banking Notification ‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌‌
  </div>

  <div class="email-wrapper">
    <div class="email-container">

      <!-- ══ HEADER ══════════════════════════════════════ -->
      <div class="header">
        <p class="logo-wordmark">FORTRESS <span>BANKING</span></p>
        <p class="logo-tagline">Trust &nbsp;·&nbsp; Strength &nbsp;·&nbsp; Security</p>
      </div>

      <!-- ══ META STRIP ══════════════════════════════════ -->
      <div class="meta-strip">
        <span class="meta-strip-inner">
          SECURE NOTIFICATION &nbsp;|&nbsp; Ref: <strong>{{applicationNumber}}</strong>
        </span>
      </div>

      <!-- ══ BODY ════════════════════════════════════════ -->
      <div class="content">

        <h1 class="email-title">{{title}}</h1>

        <div class="notice-block">
          <p class="notice-eyebrow">Action Taken</p>
          <p class="notice-text">{{actionTaken}}</p>
        </div>

        <p class="section-label">Transaction Details</p>
        <table class="info-table" role="presentation" cellpadding="0" cellspacing="0" width="100%">
          <tr>
            <th scope="row">Customer Name</th>
            <td>{{customerName}}</td>
          </tr>
          <tr>
            <th scope="row">Application No.</th>
            <td>{{applicationNumber}}</td>
          </tr>
          <tr>
            <th scope="row">Status</th>
            <td><span class="status-badge">{{status}}</span></td>
          </tr>
          {{#if transactionId}}
          <tr>
            <th scope="row">Transaction ID</th>
            <td><span class="transaction-id">{{transactionId}}</span></td>
          </tr>
          {{/if}}
        </table>

        <div class="support-block">
          <p>Need assistance with this notification?</p>
          <a href="mailto:ai-support@fb.com">ai-support@fb.com</a>
        </div>

      </div>

      <!-- ══ CONFIDENTIALITY ════════════════════════════ -->
      <div class="confidential-strip">
        <p>This communication is intended solely for the named recipient and may contain confidential information. If
          you received this in error, please delete it and notify the sender immediately.</p>
      </div>

      <!-- ══ FOOTER ══════════════════════════════════════ -->
      <div class="footer">
        <p class="footer-logo">FORTRESS <span>BANKING</span></p>
        <div class="footer-divider"></div>
        <p class="footer-powered">Powered by <strong>Converiqo.ai</strong></p>
        <p class="footer-slogan">Empowering business with intelligent automation</p>
        <p class="footer-copy">&copy; 2026 Fortress Banking Corporation. All rights reserved.</p>
        <p class="footer-links">
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Use</a>
          <a href="#">Unsubscribe</a>
        </p>
      </div>

    </div>
  </div>
</body>

</html>