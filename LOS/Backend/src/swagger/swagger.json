{
  "openapi": "3.0.0",
  "info": {
    "title": "Loan Origination System (LOS) API Document",
    "version": "1.0.0",
    "description": "Phase 2 API Documentation for the Loan Origination System (LOS) covering User and Loan Lifecycles."
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API Version 1"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "SUPER_ADMIN",
              "LOAN_OFFICER",
              "CREDIT_ANALYST",
              "APPROVER"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AuditLog": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "action": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "ipAddress": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LoanApplication": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "applicationNumber": {
            "type": "string"
          },
          "applicantName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "pan": {
            "type": "string"
          },
          "loanType": {
            "type": "string",
            "enum": [
              "PERSONAL",
              "HOME",
              "AUTO",
              "BUSINESS",
              "EDUCATION"
            ]
          },
          "loanAmount": {
            "type": "number"
          },
          "monthlyIncome": {
            "type": "number"
          },
          "employmentType": {
            "type": "string",
            "enum": [
              "SALARIED",
              "SELF_EMPLOYED",
              "BUSINESS_OWNER"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "SUBMITTED",
              "UNDER_REVIEW",
              "APPROVED",
              "REJECTED",
              "DISBURSED"
            ]
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "applicationId": {
            "type": "string",
            "format": "uuid"
          },
          "documentType": {
            "type": "string",
            "enum": [
              "PAN",
              "AADHAAR",
              "SALARY_SLIP",
              "BANK_STATEMENT"
            ]
          },
          "fileName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "VERIFIED",
              "REJECTED"
            ]
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Assessment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "applicationId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "COMPLETED"
            ]
          },
          "creditScore": {
            "type": "integer"
          },
          "riskLevel": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH"
            ]
          },
          "recommendation": {
            "type": "string",
            "enum": [
              "APPROVE",
              "MANUAL_REVIEW",
              "REJECT"
            ]
          },
          "assessmentNotes": {
            "type": "string"
          },
          "assessedById": {
            "type": "string",
            "format": "uuid"
          },
          "assessedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "User authentication",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@los.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "admin123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Login"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get authenticated user details",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile details"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "List all users (SUPER_ADMIN only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of user profiles"
          }
        }
      },
      "post": {
        "summary": "Create user profile (SUPER_ADMIN only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "firstName",
                  "lastName",
                  "role"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "analyst@los.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "analyst123"
                  },
                  "firstName": {
                    "type": "string",
                    "example": "Alice"
                  },
                  "lastName": {
                    "type": "string",
                    "example": "Smith"
                  },
                  "role": {
                    "type": "string",
                    "enum": [
                      "SUPER_ADMIN",
                      "LOAN_OFFICER",
                      "CREDIT_ANALYST",
                      "APPROVER"
                    ],
                    "example": "CREDIT_ANALYST"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "summary": "Get specific user profile by ID",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User profile details"
          }
        }
      },
      "put": {
        "summary": "Update a user profile",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated"
          }
        }
      },
      "delete": {
        "summary": "Delete user (SUPER_ADMIN only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        }
      }
    },
    "/audit-logs": {
      "get": {
        "summary": "Get system audit logs (SUPER_ADMIN only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "System audit logs"
          }
        }
      }
    },
    "/applications": {
      "get": {
        "summary": "List/Query loan applications",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "loanType",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of applications"
          }
        }
      },
      "post": {
        "summary": "Create loan application draft (LOAN_OFFICER only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "applicantName",
                  "email",
                  "phone",
                  "pan",
                  "loanType",
                  "loanAmount",
                  "monthlyIncome",
                  "employmentType"
                ],
                "properties": {
                  "applicantName": {
                    "type": "string",
                    "example": "Rahul Dev"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "rahul@gmail.com"
                  },
                  "phone": {
                    "type": "string",
                    "example": "9876543210"
                  },
                  "pan": {
                    "type": "string",
                    "example": "ABCDE1234F"
                  },
                  "loanType": {
                    "type": "string",
                    "enum": [
                      "PERSONAL",
                      "HOME",
                      "AUTO",
                      "BUSINESS",
                      "EDUCATION"
                    ],
                    "example": "HOME"
                  },
                  "loanAmount": {
                    "type": "number",
                    "example": 2500000
                  },
                  "monthlyIncome": {
                    "type": "number",
                    "example": 85000
                  },
                  "employmentType": {
                    "type": "string",
                    "enum": [
                      "SALARIED",
                      "SELF_EMPLOYED",
                      "BUSINESS_OWNER"
                    ],
                    "example": "SALARIED"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Application draft created"
          }
        }
      }
    },
    "/applications/{id}": {
      "get": {
        "summary": "Retrieve specific loan application details",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed application with decrypted/masked PAN and files list"
          }
        }
      },
      "put": {
        "summary": "Update application details (DRAFT status only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "applicantName": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "loanAmount": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Draft application updated"
          }
        }
      }
    },
    "/applications/{id}/submit": {
      "post": {
        "summary": "Submit application to the assessment flow",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Application successfully submitted"
          }
        }
      }
    },
    "/applications/{id}/status": {
      "put": {
        "summary": "Update application status (Credit/Approver RBAC)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "DRAFT",
                      "SUBMITTED",
                      "UNDER_REVIEW",
                      "APPROVED",
                      "REJECTED",
                      "DISBURSED"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application status successfully updated"
          }
        }
      }
    },
    "/documents": {
      "post": {
        "summary": "Upload a document",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "applicationId",
                  "documentType",
                  "file"
                ],
                "properties": {
                  "applicationId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "documentType": {
                    "type": "string",
                    "enum": [
                      "PAN",
                      "AADHAAR",
                      "SALARY_SLIP",
                      "BANK_STATEMENT"
                    ]
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document uploaded"
          }
        }
      }
    },
    "/documents/{id}/status": {
      "put": {
        "summary": "Verify or reject document metadata (Credit Analyst only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "PENDING",
                      "VERIFIED",
                      "REJECTED"
                    ],
                    "example": "VERIFIED"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document verification status updated"
          }
        }
      }
    },
    "/assessments": {
      "post": {
        "summary": "Run credit assessment (Credit Analyst only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "applicationId",
                  "assessmentNotes"
                ],
                "properties": {
                  "applicationId": {
                    "type": "string",
                    "format": "uuid",
                    "example": "f55c8208-8e6f-4c8d-8a6e-399d8b746c20"
                  },
                  "assessmentNotes": {
                    "type": "string",
                    "example": "Verified income via salary slip and calculated low risk."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Credit assessment completed and saved"
          }
        }
      }
    },
    "/assessments/{applicationId}": {
      "get": {
        "summary": "Get assessment details by application ID",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "applicationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Credit assessment details retrieved"
          }
        }
      }
    },
    "/offers/generate": {
      "post": {
        "summary": "Generate loan offer (Approver/Super Admin only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "applicationId",
                  "interestRate",
                  "tenureMonths"
                ],
                "properties": {
                  "applicationId": {
                    "type": "string",
                    "format": "uuid",
                    "example": "f55c8208-8e6f-4c8d-8a6e-399d8b746c20"
                  },
                  "interestRate": {
                    "type": "number",
                    "example": 10.5
                  },
                  "tenureMonths": {
                    "type": "integer",
                    "example": 24
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Loan offer generated successfully"
          }
        }
      }
    },
    "/offers/accept": {
      "post": {
        "summary": "Record Customer Acceptance of loan offer (Loan Officer/Super Admin only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "applicationId"
                ],
                "properties": {
                  "applicationId": {
                    "type": "string",
                    "format": "uuid",
                    "example": "f55c8208-8e6f-4c8d-8a6e-399d8b746c20"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer acceptance recorded successfully"
          }
        }
      }
    },
    "/disbursements": {
      "post": {
        "summary": "Execute loan disbursement (Approver/Super Admin only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "applicationId"
                ],
                "properties": {
                  "applicationId": {
                    "type": "string",
                    "format": "uuid",
                    "example": "f55c8208-8e6f-4c8d-8a6e-399d8b746c20"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Loan disbursed successfully"
          }
        }
      }
    },
    "/auth/otp/request": {
      "post": {
        "summary": "Request OTP for authentication",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@los.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent successfully"
          }
        }
      }
    },
    "/auth/otp/verify": {
      "post": {
        "summary": "Verify OTP for authentication",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "code"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@los.com"
                  },
                  "code": {
                    "type": "string",
                    "example": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP verified successfully"
          },
          "401": {
            "description": "Invalid OTP"
          }
        }
      }
    },
    "/users/{id}/role": {
      "patch": {
        "summary": "Change user role (SUPER_ADMIN only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
