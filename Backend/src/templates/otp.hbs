<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your OTP Code</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.6;
      color: #000000;
      margin: 0;
      padding: 0;
      background-color: #ffffff;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background: #ffffff;
    }
    .header {
      text-align: center;
      padding: 40px 20px 20px;
    }
    .logo-container {
      display: inline-block;
      text-align: center;
    }
    .logo-text {
      font-size: 24px;
      font-weight: bold;
      color: #002b5e;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .logo-subtext {
      font-size: 8px;
      color: #666666;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-top: 6px;
      border-top: 1px solid #eaeaea;
      padding-top: 6px;
    }
    .content {
      padding: 20px 40px 40px;
    }
    .greeting {
      font-size: 24px;
      font-weight: normal;
      margin-bottom: 20px;
      margin-top: 0;
    }
    .instructions {
      font-size: 16px;
      margin-bottom: 40px;
    }
    .code-block {
      background-color: #f7ebeb;
      border-left: 3px solid #000000;
      padding: 30px 20px;
      text-align: center;
      margin-bottom: 30px;
    }
    .code-label {
      font-size: 18px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 15px;
    }
    .code-value {
      font-size: 40px;
      font-weight: normal;
      letter-spacing: 2px;
    }
    .warning {
      text-align: center;
      font-size: 15px;
      margin-bottom: 30px;
    }
    .security-notice {
      background-color: #f7ebeb;
      border-left: 3px solid #000000;
      padding: 25px 30px;
      margin-bottom: 40px;
    }
    .security-title {
      font-size: 22px;
      font-weight: normal;
      margin-bottom: 15px;
      margin-top: 0;
    }
    .security-text {
      font-size: 15px;
      margin: 0;
    }
    .support-text {
      text-align: center;
      font-size: 16px;
      margin-bottom: 40px;
    }
    .footer {
      background-color: #000000;
      color: #ffffff;
      text-align: center;
      padding: 40px 20px;
      font-size: 15px;
    }
    .footer-powered {
      margin-bottom: 10px;
    }
    .footer-slogan {
      color: #cccccc;
      margin-bottom: 15px;
    }
    .footer-copy {
      color: #aaaaaa;
    }
    
    @media only screen and (max-width: 600px) {
      .content {
        padding: 20px 20px 30px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo-container">
        <h1 class="logo-text">FORTRESS BANKING</h1>
        <div class="logo-subtext">TRUST. STRENGTH. SECURITY.</div>
      </div>
    </div>
    
    <div class="content">
      <h1 class="greeting">Hello, {{firstName}}</h1>
      <p class="instructions">Please use the verification code below to sign into your Fortress Banking Account</p>
      
      <div class="code-block">
        <div class="code-label">VERIFICATION CODE</div>
        <div class="code-value">{{otpCode}}</div>
      </div>
      
      <div class="warning">This code expires in 10 minutes. Do not share it with anyone</div>
      
      <div class="security-notice">
        <h2 class="security-title">Security Notice</h2>
        <p class="security-text">If you did not request this verification code, please ignore this email and contact our support team immediately.</p>
      </div>
      
      <div class="support-text">Need assistance? contact ai-support@fb.com</div>
    </div>
    
    <div class="footer">
      <div class="footer-powered">Powered By Converiqo.ai</div>
      <div class="footer-slogan">Empowering business with intelligent automation</div>
      <div class="footer-copy">&copy; 2026 Fortress Banking. All rights reserved</div>
    </div>
  </div>
</body>
</html>
