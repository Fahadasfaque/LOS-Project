<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Your OTP Code</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: #f4f7f6;
    }
    .container {
      max-width: 600px;
      margin: 20px auto;
      padding: 30px;
      background: #ffffff;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
      border-bottom: 1px solid #eee;
      padding-bottom: 20px;
    }
    .header h1 {
      color: #2563eb;
      margin: 0;
    }
    .content {
      text-align: center;
    }
    .otp-code {
      font-size: 36px;
      font-weight: bold;
      letter-spacing: 4px;
      color: #1e3a8a;
      background: #f1f5f9;
      padding: 15px 30px;
      border-radius: 8px;
      display: inline-block;
      margin: 20px 0;
    }
    .footer {
      margin-top: 30px;
      padding-top: 20px;
      text-align: center;
      font-size: 12px;
      color: #6b7a9e;
      border-top: 1px solid #eee;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Fortress Lending</h1>
    </div>
    <div class="content">
      <h2>Login Verification Code</h2>
      <p>Hello {{firstName}},</p>
      <p>Please use the following 6-digit code to complete your login. This code will expire in 10 minutes.</p>
      <div class="otp-code">{{otpCode}}</div>
      <p>If you did not request this code, please ignore this email or contact support.</p>
    </div>
    <div class="footer">
      <p>&copy; {{year}} Fortress Lending. All rights reserved.</p>
      <p>This is an automated message, please do not reply.</p>
    </div>
  </div>
</body>
</html>
