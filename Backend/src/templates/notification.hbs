<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.6;
      color: #000000;
      margin: 0;
      padding: 0;
      background-color: #ffffff;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background: #ffffff;
    }
    .header {
      text-align: center;
      padding: 40px 20px 20px;
    }
    .logo-container {
      display: inline-block;
      text-align: center;
    }
    .logo-text {
      font-size: 24px;
      font-weight: bold;
      color: #002b5e;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .logo-subtext {
      font-size: 8px;
      color: #666666;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-top: 6px;
      border-top: 1px solid #eaeaea;
      padding-top: 6px;
    }
    .content {
      padding: 20px 40px 40px;
    }
    .greeting {
      font-size: 24px;
      font-weight: normal;
      margin-bottom: 30px;
      margin-top: 0;
    }
    .notice-block {
      background-color: #f7ebeb;
      border-left: 3px solid #000000;
      padding: 25px 30px;
      margin-bottom: 40px;
    }
    .notice-title {
      font-size: 20px;
      font-weight: normal;
      margin-bottom: 10px;
      margin-top: 0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .notice-text {
      font-size: 16px;
      margin: 0;
    }
    .info-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 40px;
    }
    .info-table th, .info-table td {
      padding: 15px 0;
      border-bottom: 1px solid #eaeaea;
      text-align: left;
      font-size: 16px;
    }
    .info-table th {
      color: #666666;
      font-weight: normal;
      width: 45%;
    }
    .info-table td {
      font-weight: bold;
    }
    .support-text {
      text-align: center;
      font-size: 16px;
      margin-bottom: 40px;
    }
    .footer {
      background-color: #000000;
      color: #ffffff;
      text-align: center;
      padding: 40px 20px;
      font-size: 15px;
    }
    .footer-powered {
      margin-bottom: 10px;
    }
    .footer-slogan {
      color: #cccccc;
      margin-bottom: 15px;
    }
    .footer-copy {
      color: #aaaaaa;
    }
    
    @media only screen and (max-width: 600px) {
      .content {
        padding: 20px 20px 30px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo-container">
        <h1 class="logo-text">FORTRESS BANKING</h1>
        <div class="logo-subtext">TRUST. STRENGTH. SECURITY.</div>
      </div>
    </div>
    
    <div class="content">
      <h1 class="greeting">{{title}}</h1>
      
      <div class="notice-block">
        <h2 class="notice-title">Action Taken</h2>
        <p class="notice-text">{{actionTaken}}</p>
      </div>

      <table class="info-table">
        <tr>
          <th>Customer Name</th>
          <td>{{customerName}}</td>
        </tr>
        <tr>
          <th>Application Number</th>
          <td>{{applicationNumber}}</td>
        </tr>
        <tr>
          <th>Status</th>
          <td>{{status}}</td>
        </tr>
        {{#if transactionId}}
        <tr>
          <th>Transaction ID</th>
          <td>{{transactionId}}</td>
        </tr>
        {{/if}}
      </table>
      
      <div class="support-text">Need assistance? contact ai-support@fb.com</div>
    </div>
    
    <div class="footer">
      <div class="footer-powered">Powered By Converiqo.ai</div>
      <div class="footer-slogan">Empowering business with intelligent automation</div>
      <div class="footer-copy">&copy; 2026 Fortress Banking. All rights reserved</div>
    </div>
  </div>
</body>
</html>